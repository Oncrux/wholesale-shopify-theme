{% comment %}
  Country calling codes for phone inputs.

  Renders either the <option> tags for a calling-code selector, or just the dial
  code of the resolved country so a tel input can be pre-filled server-side (and
  therefore still works with JavaScript disabled).

  Accepts:
  - mode: {String} 'options' (default) renders <option> tags, 'dial' renders only
    the resolved dial code (e.g. "+1") with no surrounding markup.
  - selected_iso: {String} ISO code of the country to resolve to. Falls back to
    the storefront's active country, then to US.

  Usage:
  <select ...>
    {% render 'phone-country-codes' %}
  </select>

  {%- capture default_dial -%}
    {% render 'phone-country-codes', mode: 'dial' %}
  {%- endcapture -%}
{% endcomment %}

{%- liquid
  assign requested_iso = selected_iso | default: localization.country.iso_code | upcase

  comment
    Each row is "ISO|Country name|dial code|flag". Scoped to the markets we ship
    to rather than every calling code â€” add rows here as markets are added.
  endcomment
  assign country_rows = 'US|United States|+1|đź‡şđź‡¸,CA|Canada|+1|đź‡¨đź‡¦,GB|United Kingdom|+44|đź‡¬đź‡§,IE|Ireland|+353|đź‡®đź‡Ş,AU|Australia|+61|đź‡¦đź‡ş,NZ|New Zealand|+64|đź‡łđź‡ż,DE|Germany|+49|đź‡©đź‡Ş,FR|France|+33|đź‡«đź‡·,ES|Spain|+34|đź‡Şđź‡¸,IT|Italy|+39|đź‡®đź‡ą,NL|Netherlands|+31|đź‡łđź‡±,BE|Belgium|+32|đź‡§đź‡Ş,AT|Austria|+43|đź‡¦đź‡ą,CH|Switzerland|+41|đź‡¨đź‡­,SE|Sweden|+46|đź‡¸đź‡Ş,NO|Norway|+47|đź‡łđź‡´,DK|Denmark|+45|đź‡©đź‡°,FI|Finland|+358|đź‡«đź‡®,PL|Poland|+48|đź‡µđź‡±,CZ|Czechia|+420|đź‡¨đź‡ż,PT|Portugal|+351|đź‡µđź‡ą,JP|Japan|+81|đź‡Żđź‡µ,KR|South Korea|+82|đź‡°đź‡·,SG|Singapore|+65|đź‡¸đź‡¬,MX|Mexico|+52|đź‡˛đź‡˝,BR|Brazil|+55|đź‡§đź‡·,ZA|South Africa|+27|đź‡żđź‡¦' | split: ','

  assign resolved_iso = 'US'
  for row in country_rows
    assign row_iso = row | split: '|' | first
    if row_iso == requested_iso
      assign resolved_iso = requested_iso
      break
    endif
  endfor
-%}

{%- if mode == 'dial' -%}
  {%- for row in country_rows -%}
    {%- assign parts = row | split: '|' -%}
    {%- if parts[0] == resolved_iso -%}{{ parts[2] }}{%- break -%}{%- endif -%}
  {%- endfor -%}
{%- else -%}
  {%- for row in country_rows -%}
    {%- liquid
      assign parts = row | split: '|'
      assign row_iso = parts[0]
      assign row_name = parts[1]
      assign row_dial = parts[2]
      assign row_flag = parts[3]
    -%}
    <option
      value="{{ row_dial }}"
      data-country-iso="{{ row_iso }}"
      {% if row_iso == resolved_iso %}selected{% endif %}
    >
      {{ row_flag }} {{ row_name }} ({{ row_dial }})
    </option>
  {%- endfor -%}
{%- endif -%}
